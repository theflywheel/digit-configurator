{
  "name": "@digit-mcp/data-provider",
  "version": "0.1.0",
  "description": "Shared DIGIT platform API client, react-admin DataProvider, and AuthProvider",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./client": {
      "import": "./dist/client/index.js",
      "types": "./dist/client/index.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test src/**/*.test.ts",
    "test:integration": "node --import tsx --test src/providers/dataProvider.integration.test.ts",
    "test:watch": "node --import tsx --test --watch src/**/*.test.ts"
  },
  "dependencies": {
    "@digit-mcp/data-provider": "^0.1.0"
  },
  "peerDependencies": {
    "ra-core": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "ra-core": {
      "optional": true
    }
  },
  "devDependencies": {
    "ra-core": "^5.0.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0"
  }
}
